  margin-bottom: 20px;
}

.button {
  display: inline-block;
  padding: 10px 18px;
  background: #7a9e87;
  color: white;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 500;
  font-size: 0.85rem;
  transition: 0.2s;
  text-align: center;
